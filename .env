#--------------------------------------------------------------------
# ENVIRONMENT — development menampilkan error detail, production menyembunyikan
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
#app.baseURL              = 'http://localhost:8080/'
app.baseURL              = 'https://web-elearning-jet.vercel.app/'
app.sessionDriver        = 'CodeIgniter\Session\Handlers\FileHandler'
app.sessionCookieName    = 'elearn_session'
app.sessionExpiration    = 7200
app.sessionSavePath      = writable\session
app.CSRFProtection       = false
app.CSRFTokenName        = 'csrf_token'
app.CSRFCookieName       = 'csrf_cookie'
app.CSRFExpire           = 7200
app.CSRFRegenerate       = true

#--------------------------------------------------------------------
# SUPABASE — wajib diisi
# Dapatkan dari: https://supabase.com/dashboard/project/_/settings/api
#--------------------------------------------------------------------
SUPABASE_URL         = yoururlsupabase
SUPABASE_ANON_KEY    = yourkey
SUPABASE_SERVICE_KEY = yourkey

#--------------------------------------------------------------------
# DATABASE — opsional jika pdo_pgsql sudah aktif di PHP
# Jika tidak ada, tidak masalah — semua query pakai REST API
#--------------------------------------------------------------------
# database.default.hostname = db.YOUR_PROJECT_REF.supabase.co
# database.default.database = postgres
# database.default.username = postgres
# database.default.password  = YOUR_DB_PASSWORD
# database.default.DBDriver = Postgre
# database.default.port     = 5432
# database.default.DBDebug  = false
